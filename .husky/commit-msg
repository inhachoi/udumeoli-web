IFS= read -r commit_subject < "$1"
pattern='^(feat|fix|refactor|chore|docs|style|test|ci)(\(.+\))?: .+'
if ! printf '%s\n' "$commit_subject" | grep -qE "$pattern"; then
  echo "❌ 커밋 메시지 형식 오류"
  echo "   형식: <type>: <요약>"
  echo "   허용 type: feat, fix, refactor, chore, docs, style, test, ci"
  echo "   예시: feat: 로그인 기능 추가"
  exit 1
fi
